{
  "framework": "nextjs",
  "buildCommand": "npm run prisma:deploy && npm run build && (test -z \"$SENTRY_AUTH_TOKEN\" || npm run sentry:sourcemaps)",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/recompute-leaderboard",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-community-posts",
      "schedule": "0 4 * * *"
    }
  ]
}
