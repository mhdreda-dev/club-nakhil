; Sentry's Next.js plugin (v9) declares peer next@"^13 || ^14 || ^15.0.0-rc.0"
; and hasn't yet widened the range to include Next 16, even though the plugin
; runs fine against it. Accept the peer-dep mismatch so installs don't fail.
; Remove this line once @sentry/nextjs ships a version with `|| ^16` in peers.
legacy-peer-deps=true
